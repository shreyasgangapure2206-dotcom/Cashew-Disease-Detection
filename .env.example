# Cashew Disease Detection - Environment Variables
# Copy this file to .env and fill in your values

# Security (REQUIRED)
SECRET_KEY=your-secret-key-here-change-this-in-production

# Database
DATABASE_URL=sqlite:///cashew_diagnostics.db

# AI Configuration - Ollama (Local LLM)
# Install Ollama from: https://ollama.ai
# Start with: ollama serve
# Pull model: ollama pull llama3.2
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Server Configuration
FLASK_ENV=production
FLASK_DEBUG=False
HOST=0.0.0.0
PORT=5000

# File Upload
MAX_FILE_SIZE=5242880  # 5MB in bytes
UPLOAD_FOLDER=static/uploads

# Model Configuration
MODEL_PATH=models/cashew_model.keras
IMG_SIZE=224
CONFIDENCE_THRESHOLD=60.0

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Rate Limiting
API_RATE_LIMIT=100
API_PREDICT_LIMIT=10

# CORS (if needed for external API access)
CORS_ENABLED=False
CORS_ORIGINS=*

# Session
SESSION_TIMEOUT=3600  # 1 hour

# Email (optional - for notifications)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Monitoring (optional)
SENTRY_DSN=your-sentry-dsn-here

# Production Settings
WORKERS=4
THREADS=2
